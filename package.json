{
  "name": "obsidian-codec",
  "version": "1.0.1",
  "description": "A codec plugin for Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node build-production.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --config eslint.config.mjs \"src/**/*.ts\"",
    "test": "vitest run",
    "deploy": "node copy-to-obsidian.mjs"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "codec"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/js-beautify": "^1.14.3",
    "@types/node": "^18.19.67",
    "builtin-modules": "3.3.0",
    "esbuild": "^0.17.3",
    "eslint": "^9.17.0",
    "eslint-plugin-obsidianmd": "^0.2.0",
    "globals": "^15.15.0",
    "jsdom": "^25.0.1",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "4.9.5",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@types/crypto-js": "^4.2.2",
    "crypto-js": "^4.2.0",
    "js-beautify": "^1.15.4"
  }
}
