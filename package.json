{
  "name": "obsidian-codec",
  "version": "1.0.1",
  "description": "A codec plugin for Obsidian",
  "main": "main.js",
  "scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "npm run lint && node esbuild.config.mjs --production && node copy-to-obsidian.mjs",
		"lint": "eslint src --ext .ts",
		"deploy": "node copy-to-obsidian.mjs"
	},
  "keywords": [
    "obsidian",
    "plugin",
    "codec"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^16.11.6",
    "@typescript-eslint/eslint-plugin": "5.29.0",
    "@typescript-eslint/parser": "5.29.0",
    "builtin-modules": "3.3.0",
    "esbuild": "^0.17.3",
    "eslint": "^8.57.0",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "4.9.5"
  },
  "dependencies": {
    "@types/crypto-js": "^4.2.2",
    "crypto-js": "^4.2.0"
  }
}
